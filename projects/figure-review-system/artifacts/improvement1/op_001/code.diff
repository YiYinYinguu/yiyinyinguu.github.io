+def fill_centered_gradient_between_bounds(
+    ax,
+    x,
+    center,
+    lower,
+    upper,
+    base_color,
+    layers=40,
+    alpha_center=0.35,
+    alpha_edge=0.02,
+    smooth_sigma=0,
+    clip_center=True,
+    zorder=1
+):
+    # no NaNs and convert to numpy arrays
+    x = np.asarray(x, dtype=float)
+    c = np.asarray(center, dtype=float)
+    lo = np.asarray(lower, dtype=float)
+    hi = np.asarray(upper, dtype=float)
+    mask = np.isfinite(x) & np.isfinite(c) & np.isfinite(lo) & np.isfinite(hi)
+    x, c, lo, hi = x[mask], c[mask], lo[mask], hi[mask]
+
+    # rank sort by x to ensure proper polygon drawing
+    order = np.argsort(x)
+    x, c, lo, hi = x[order], c[order], lo[order], hi[order]
+
+    if smooth_sigma and gaussian_filter1d is not None:
+        c  = gaussian_filter1d(c,  smooth_sigma)
+        lo = gaussian_filter1d(lo, smooth_sigma)
+        hi = gaussian_filter1d(hi, smooth_sigma)
+
+    # fix min and max values
+    lo2 = np.minimum(lo, hi)
+    hi2 = np.maximum(lo, hi)
+    if clip_center:
+        c = np.clip(c, lo2, hi2)
+
+    t = np.linspace(0, 1, layers + 1)
+    # lower: c -> lo2
+    Ls = [c * (1 - s) + lo2 * s for s in t]
+    # upper: c -> hi2
+    Us = [c * (1 - s) + hi2 * s for s in t]
+
+    alphas = alpha_center + (alpha_edge - alpha_center) * t[1:]
+    base_rgba = np.array(to_rgba(base_color))
+
+    segments, colors = [], []
+    for i in range(layers):
+        a = float(max(0.0, alphas[i]))
+        rgba = base_rgba.copy(); rgba[3] = a
+
+        poly_low = np.vstack([
+            np.column_stack([x, Ls[i+1]]),
+            np.column_stack([x[::-1], Ls[i][::-1]])
+        ])
+        segments.append(poly_low); colors.append(rgba)
+
+        poly_up = np.vstack([
+            np.column_stack([x, Us[i+1]]),
+            np.column_stack([x[::-1], Us[i][::-1]])
+        ])
+        segments.append(poly_up); colors.append(rgba)
+
+    coll = PolyCollection(
+        segments,
+        facecolors=colors,
+        edgecolors='none',
+        antialiased=True,
+        zorder=zorder,
+        clip_on=True
+    )
+    ax.add_collection(coll)
+
+
